数据库配置：
CREATE DATABASE IF NOT EXISTS jobmate_db;   CREATE USER IF NOT EXISTS 'jobmate_admin'@'localhost' IDENTIFIED BY 'jobmate_password';   GRANT ALL PRIVILEGES ON jobmate_db.* TO 'jobmate_admin'@'localhost';   FLUSH PRIVILEGES;   EXIT;
